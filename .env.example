# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Ollama Local LLM Runtime
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral  # or llama2, neural-chat, etc.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text  # for embeddings
OLLAMA_TIMEOUT=300

# Alternative LLM Providers
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=

# Vector Database
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=research_documents

# Alternative Vector Stores
PINECONE_API_KEY=
PINECONE_INDEX_NAME=research-documents
PINECONE_ENVIRONMENT=us-west1-gcp

WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

POSTGRES_URL=postgresql://user:password@localhost:5432/research_db
POSTGRES_POOL_SIZE=20

# Web Search APIs
SERPER_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
BRAVE_SEARCH_API_KEY=

# Document Processing
PDF_EXTRACTION_METHOD=pymupdf  # or 'pdfplumber', 'pypdf'
MAX_FILE_SIZE_MB=500
TEMP_DIR=./temp

# Research Configuration
RESEARCH_TEMP_DIR=./research_output
RESEARCH_CACHE_DIR=./cache
RESEARCH_TIMEOUT_SECONDS=3600
PARALLEL_RESEARCH_TASKS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# RAG Configuration
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.6
RERANK_TOP_K=5

# GraphRAG Configuration
GRAPHRAG_KNOWLEDGE_GRAPH_SIZE_LIMIT=5000
GRAPHRAG_MAX_HOPS=3
GRAPHRAG_SIMILARITY_CUTOFF=0.5

# Fact Checking
FACT_CHECK_ENABLED=true
FACT_CHECK_CONFIDENCE_THRESHOLD=0.75

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4
API_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/research_agent.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Development
DEBUG=false
ENVIRONMENT=development
